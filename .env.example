# Server-only OpenAI configuration.
# Nuxt maps private runtime config from NUXT_* environment variables.
NUXT_OPENAI_API_KEY=
NUXT_OPENAI_MODEL=

# Optional local aliases for non-Nuxt scripts.
OPENAI_API_KEY=
OPENAI_MODEL=

# Optional feature flags
CLOSEGUARDIAN_ENABLE_WEB_SEARCH=false

# Server-side storage/config placeholders
CLOSEGUARDIAN_EVIDENCE_STORAGE_PATH=
